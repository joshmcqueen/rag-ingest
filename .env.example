# Copy this file to .env and uncomment one provider block.
# Priority: CLI args > .env values > built-in defaults (Ollama)

# -- Langfuse (SDK v3: use LANGFUSE_HOST, not LANGFUSE_BASE_URL) ---
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# --- Ollama ---
LLM_HOST=http://192.168.0.58:11434
LLM_MODEL=qwen3.6:35b
LLM_API_KEY=ollama
LLM_TIMEOUT=300

# --- LM Studio ---
# LLM_HOST=http://192.168.0.58:1234
# LLM_MODEL=qwen/qwen3.6-35b-a3b
# LLM_API_KEY=lm-studio
# LLM_TIMEOUT=300

# --- Scraper ---
# DOWNLOADS_DIR=/absolute/path/to/downloads
